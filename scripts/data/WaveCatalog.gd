static func wave_count() -> int:
	return WAVES.size()

static func max_wave() -> int:
	return WAVES.size()

static func wave_for(index: int) -> Dictionary:
	var safe_index := clampi(index, 1, WAVES.size()) - 1
	return WAVES[safe_index].duplicate(true)

static func title_for_wave(index: int) -> String:
	return String(wave_for(index).get("title", "Lone Snake"))
